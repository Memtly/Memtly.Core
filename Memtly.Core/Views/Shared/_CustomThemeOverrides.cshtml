@using Memtly.Core.Constants
@using Memtly.Core.Extensions
@inject Memtly.Core.Helpers.Database.IDatabaseHelper _database

@{
    var settings = (await _database.GetSettingsStartingWith(MemtlyConfiguration.Themes.ColourOverrides.BaseKey))?.ToDictionary(x => x.Id.ToUpper(), x => x.Value ?? string.Empty);
    if (settings != null)
    {
        <style>
            :root {
                /* Navbar */
                --navbar-text: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.NavbarText.ToUpper(), "#282828")?.ToRgbColor();
                --navbar-bg: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.NavbarBackground.ToUpper(), "#FFFFFF")?.ToRgbColor();
                /* Background */
                --body-bg: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Background.ToUpper(), "#FFFFFF")?.ToRgbColor();
                /* Colour Scheme (Primary) */
                --primary-1: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Primary1.ToUpper(), "#1D4ED8")?.ToRgbColor();
                --primary-2: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Primary2.ToUpper(), "#2563EB")?.ToRgbColor();
                --primary-3: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Primary3.ToUpper(), "#3B82F6")?.ToRgbColor();
                /* Colour Scheme (Secondary) */
                --secondary-1: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Secondary1.ToUpper(), "#6366F1")?.ToRgbColor();
                --secondary-2: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Secondary2.ToUpper(), "#818CF8")?.ToRgbColor();
                /*
                    /* Colour Scheme (Danger) */
                    --danger-1: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Danger.ToUpper(), "#EF4444")?.ToRgbColor();
                    /* Colour Scheme (Disabled) */
                    --disabled-1: @settings.GetValue(MemtlyConfiguration.Themes.ColourOverrides.Disabled.ToUpper(), "#969696")?.ToRgbColor();
                */
            }
        </style>
    }
}